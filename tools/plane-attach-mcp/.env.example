# plane-attach-mcp — configuration reference.
#
# The server reads these from its process environment; it does NOT auto-load
# this file. Supply them through your MCP client's `env` block (see README),
# e.g. `claude mcp add plane-attach -e PLANE_API_KEY=... -- node .../server.mjs`.
#
# Keep real values in a local, git-ignored .env:  cp .env.example .env

# Required — Plane personal API token (Plane → Settings → API tokens). SECRET.
PLANE_API_KEY=

# Required — workspace slug as it appears in Plane URLs (app.plane.so/<slug>/).
PLANE_WORKSPACE_SLUG=beta-werkz

# Optional — API base URL. Default: https://api.plane.so (override for self-hosted).
#PLANE_BASE_URL=https://api.plane.so

# Optional — confine attachable files to this directory tree. Default: unrestricted.
#PLANE_ATTACH_ROOT=

# Optional — throttle between uploads, in milliseconds. Default: 0.
#PLANE_THROTTLE_MS=0
